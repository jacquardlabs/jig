#!/usr/bin/env python3
"""jig's verify script (story build-scripts, issue #14).

Independently re-runs a task's Done-means items — one PASS/FAIL per item,
never a single suite-level boolean — instead of trusting the executor's
claim that they're satisfied (docs/design/build-scripts.md, "Proposed
design"; PRODUCT.md's "Nothing signs off on itself" principle). Consumes an
already-extracted item list (a small JSON document — see the module-level
`ITEMS_SCHEMA` note below), not raw `PLAN.md` checkpoint-block prose;
parsing that grammar for real is `/plan`'s (M3) job.

Each item names a verification tier (`script` | `test-backed` | `probe` —
DESIGN.md's closed enum; no `judgment` tier permitted):

- `script` / `test-backed`: runs the item's own named `command` via the
  shell and checks its exit code.
- `probe`: confirms a caller-supplied `artifact` file exists, is non-empty,
  and (if given) matches an expected `pattern` — verify never takes the
  screenshot or runs `ps` on the executor's behalf, since choosing what
  observation proves a capability is the checkpoint-block author's call,
  not a generic script's to invent.

Every item — `cap` and `hold` alike — must PASS for the overall result to
be PASS; per-item results are always reported, even on an overall PASS, so
a caller can tell whether a repeat failure lands on the *same* item as
before.

Fails closed rather than passing vacuously: an empty or malformed item list
is a usage error (exit 2), never a PASS (docs/studious/premortems/
build-scripts.md, risk #4). A `probe` item also needs `--since` — an
ISO-8601 timestamp or a git revision — so a stale artifact copied forward
from a prior attempt can't pass just because no `pattern` was supplied
(same premortem doc, risk #5); this recency floor is verify's own, not
merely delegated to the downstream `evidence-capture` freshness check.

ITEMS_SCHEMA (JSON):
    {
      "task": "task-1",
      "items": [
        {"id": 1, "kind": "cap", "tier": "script", "command": "ruff check x.py"},
        {"id": 2, "kind": "hold", "tier": "test-backed", "command": "python -m unittest tests.test_x.Case.test_y"},
        {"id": 3, "kind": "cap", "tier": "probe", "artifact": "path/to/evidence.txt", "pattern": "no orphaned process"}
      ]
    }

Exit codes: 0 every item PASS. 1 at least one item FAIL. 2 usage error
(malformed/empty items, missing --since for a probe item).
"""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from dataclasses import asdict, dataclass
from datetime import datetime
from pathlib import Path
from textwrap import indent

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _gitutil import resolve_revision_epoch  # noqa: E402

VALID_KINDS = frozenset({"cap", "hold"})
VALID_TIERS = frozenset({"script", "test-backed", "probe"})
COMMAND_TIERS = frozenset({"script", "test-backed"})


@dataclass
class ItemResult:
    id: object
    kind: str
    tier: str
    status: str  # PASS | FAIL
    detail: str


def load_items(path: Path) -> dict:
    """Load and validate the items document; raises ValueError on any problem."""
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise ValueError(f"could not read items file '{path}': {exc}") from exc
    except json.JSONDecodeError as exc:
        raise ValueError(f"items file '{path}' is not valid JSON: {exc}") from exc

    if not isinstance(data, dict) or "items" not in data:
        raise ValueError(f"items file '{path}' must be a JSON object with an 'items' list")

    items = data["items"]
    if not isinstance(items, list) or not items:
        raise ValueError("no items to verify: 'items' must be a non-empty list")

    for i, item in enumerate(items):
        label = f"item #{i}"
        if not isinstance(item, dict):
            raise ValueError(f"{label} is not a JSON object")
        if "id" not in item:
            raise ValueError(f"{label} is missing required field 'id'")
        label = f"item {item['id']!r}"

        kind = item.get("kind")
        if kind not in VALID_KINDS:
            raise ValueError(f"{label}: 'kind' must be one of {sorted(VALID_KINDS)}, got {kind!r}")

        tier = item.get("tier")
        if tier not in VALID_TIERS:
            raise ValueError(
                f"{label}: 'tier' must be one of {sorted(VALID_TIERS)}, got {tier!r} "
                "(no 'judgment' tier permitted)"
            )

        if tier in COMMAND_TIERS and not item.get("command"):
            raise ValueError(f"{label}: tier '{tier}' requires a non-empty 'command'")
        if tier == "probe" and not item.get("artifact"):
            raise ValueError(f"{label}: tier 'probe' requires a non-empty 'artifact' path")

    return data


def resolve_since(since: str, repo: Path) -> float:
    """Resolve --since to a POSIX epoch: an ISO-8601 timestamp or a git revision."""
    try:
        return datetime.fromisoformat(since.replace("Z", "+00:00")).timestamp()
    except ValueError:
        pass
    epoch = resolve_revision_epoch(repo, since)
    if epoch is None:
        raise ValueError(
            f"--since value '{since}' is neither an ISO-8601 timestamp nor a "
            "resolvable git revision"
        )
    return epoch


def check_command_item(item: dict, repo: Path) -> ItemResult:
    result = subprocess.run(
        item["command"], shell=True, cwd=repo, capture_output=True, text=True, check=False
    )
    status = "PASS" if result.returncode == 0 else "FAIL"
    detail = (
        f"command: {item['command']}\n"
        f"exit code: {result.returncode}\n"
        f"--- stdout ---\n{result.stdout}\n--- stderr ---\n{result.stderr}"
    )
    return ItemResult(item["id"], item["kind"], item["tier"], status, detail)


def check_probe_item(item: dict, since_ts: float) -> ItemResult:
    artifact = Path(item["artifact"])
    if not artifact.is_file():
        return ItemResult(item["id"], item["kind"], item["tier"], "FAIL", f"artifact not found: {artifact}")
    if artifact.stat().st_size == 0:
        return ItemResult(item["id"], item["kind"], item["tier"], "FAIL", f"artifact is empty: {artifact}")
    if artifact.stat().st_mtime < since_ts:
        return ItemResult(
            item["id"], item["kind"], item["tier"], "FAIL",
            f"artifact is stale — its mtime predates --since: {artifact}",
        )
    pattern = item.get("pattern")
    if pattern and not re.search(pattern, artifact.read_text(encoding="utf-8", errors="replace")):
        return ItemResult(
            item["id"], item["kind"], item["tier"], "FAIL",
            f"artifact does not match expected pattern {pattern!r}: {artifact}",
        )
    return ItemResult(item["id"], item["kind"], item["tier"], "PASS", f"artifact ok: {artifact}")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="verify",
        description="Independently re-run a task's Done-means items, one PASS/FAIL per item.",
    )
    parser.add_argument("--items", required=True, help="path to the task's items JSON document")
    parser.add_argument(
        "--repo", default=".", help="working directory for 'command' tiers and for resolving --since as a git revision"
    )
    parser.add_argument(
        "--since",
        default=None,
        help="ISO-8601 timestamp or git revision a 'probe' artifact must not predate",
    )
    parser.add_argument("--out", default=None, help="path to write a JSON results document")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)

    try:
        data = load_items(Path(args.items))
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 2

    items = data["items"]
    repo = Path(args.repo).resolve()
    has_probe = any(item["tier"] == "probe" for item in items)

    since_ts: float | None = None
    if args.since is not None:
        try:
            since_ts = resolve_since(args.since, repo)
        except ValueError as exc:
            print(f"error: {exc}", file=sys.stderr)
            return 2
    elif has_probe:
        print(
            "error: items include a 'probe'-tier check but no --since was given. "
            "A probe artifact needs a freshness floor (e.g. the task's start time "
            "or the worktree's baseline commit) or a stale artifact copied forward "
            "from a prior attempt would pass silently.",
            file=sys.stderr,
        )
        return 2

    results = [
        check_probe_item(item, since_ts) if item["tier"] == "probe" else check_command_item(item, repo)
        for item in items
    ]

    for r in results:
        print(f"[{r.status}] item {r.id} ({r.kind}/{r.tier})")
        if r.status == "FAIL":
            print(indent(r.detail, "    "))

    passed = sum(r.status == "PASS" for r in results)
    overall = "PASS" if passed == len(results) else "FAIL"
    print(f"verify: task={data.get('task', '?')} overall={overall} ({passed}/{len(results)} items pass)")

    if args.out:
        Path(args.out).write_text(
            json.dumps(
                {"task": data.get("task"), "overall": overall, "items": [asdict(r) for r in results]},
                indent=2,
            ),
            encoding="utf-8",
        )

    return 0 if overall == "PASS" else 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
